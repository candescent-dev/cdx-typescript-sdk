# Candescent Digital Insight TypeScript SDK — Environment Variables Template
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# DO NOT commit .env with real credentials — it is listed in .gitignore.

# ── Required for most examples ─────────────────────────────────────────────
CANDESCENT_INSTITUTION_ID=your-institution-id
CANDESCENT_CLIENT_ID=your-client-id
CANDESCENT_CLIENT_SECRET=your-client-secret

# ── Optional: API environment (defaults to "stage") ────────────────────────
# CANDESCENT_ENVIRONMENT=stage
# CANDESCENT_ENVIRONMENT=production

# ── Optional: Skip OAuth (use a pre-obtained bearer token) ─────────────────
# CANDESCENT_BEARER_TOKEN=your-static-bearer-token

# ── Optional: Password grant (instead of client_credentials) ─────────────
# CANDESCENT_USERNAME=your-username
# CANDESCENT_PASSWORD=your-password

# ── Example-specific: User identifiers (use ONE of hostUserId or loginId) ─
CANDESCENT_HOST_USER_ID=your-host-user-id
# CANDESCENT_LOGIN_ID=your-login-id

# ── Example-specific: Customer & user IDs ──────────────────────────────────
CANDESCENT_CUSTOMER_ID=your-customer-guid
# CANDESCENT_INSTITUTION_USER_ID=your-institution-user-id
# CANDESCENT_INSTITUTION_CUSTOMER_ID=your-institution-customer-id

# ── Example-specific: Account & subscription IDs ─────────────────────────
CANDESCENT_ACCOUNT_ID=your-account-id
# CANDESCENT_SUBSCRIPTION_ID=your-subscription-id

# ── Example-specific: Alert configuration ──────────────────────────────────
# CANDESCENT_ALERT_TEMPLATE_ID=your-alert-template-id
# CANDESCENT_ALERT_TYPE_NAME=your-alert-type-name
# CANDESCENT_ALERT_PREF_ID=your-alert-preference-id
# CANDESCENT_ALERT_CONTACT_EMAIL=you@example.com

# ── authentication.ts: OIDC auth-code flow ────────────────────────────────
# CANDESCENT_OIDC_CLIENT_ID=your-oidc-client-id
# CANDESCENT_APIGEE_BASE_URL=https://api.example.com/digitalbanking/stage
# CANDESCENT_AUTH_NONCE=your-nonce

# ── Business banking (business-entitlements, business-payments) ───────────
# CANDESCENT_BB_CLIENT_ID=your-bb-client-id
# CANDESCENT_BB_CLIENT_SECRET=your-bb-client-secret
# CANDESCENT_BB_INSTITUTION_ID=your-bb-institution-id
# CANDESCENT_BB_LOGIN_ID=your-bb-login-id
# CANDESCENT_BB_BUSINESS_ID=your-bb-business-id
# CANDESCENT_BB_INSTITUTION_CUSTOMER_ID=your-bb-institution-customer-id
# CANDESCENT_BB_FEATURE_NAME=your-bb-feature-name

# ── MX integration (mx-service example) ───────────────────────────────────
# CANDESCENT_MX_CLIENT_ID=your-mx-client-id
# CANDESCENT_MX_CLIENT_SECRET=your-mx-client-secret
# CANDESCENT_MX_INSTITUTION_ID=your-mx-institution-id
# CANDESCENT_MX_HOST=int-widgets.moneydesktop.com
# CANDESCENT_MX_USER_ID=your-mx-user-id

# ── Optional: Fallback IDs (skip resource creation in lookup examples) ─────
# FALLBACK_CUSTOMER_ID=your-known-customer-guid
